# Server
PORT=5000
NODE_ENV=development

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hospital_rotation_db
DB_USER=root
DB_PASSWORD=changeme
# Set to true for managed hosts (Railway, PlanetScale, etc.) that require SSL
DB_SSL=false

# JWT
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=8h

# Production only: the deployed frontend origin, so CORS isn't wide open.
# Example: https://your-app.vercel.app
FRONTEND_URL=

# Notifications - leave blank to run in MOCK mode (logs to console + DB only)
NOTIFY_MODE=mock
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Rotation completion rule
MIN_WEEKS_FOR_COMPLETION=3
BLOCK_TOTAL_WEEKS=4
